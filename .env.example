# Preprocessing Pipeline Configuration

# Data paths
RAW_DATA_PATH=data/raw/online_retail_II.xlsx
OUTPUT_DIR=data/processed

# Filtering parameters
MIN_SUPPORT_COUNT=50
MIN_SUPPORT_PERCENTAGE=0.1
MIN_ITEMS_PER_TRANSACTION=2

# ================================================================
# Frequent Itemset Mining Algorithm Parameters
# ================================================================

# Common parameters for all algorithms
MINING_MIN_SUPPORT=100
MINING_MIN_CONFIDENCE=0.5

# Apriori specific parameters
APRIORI_USE_HASH_TREE=True

# Hash Tree parameters (used in Apriori when USE_HASH_TREE=true)
HASH_TREE_MAX_LEAF_COUNT=20
HASH_TREE_MODULO=100
HASH_TREE_ITEM_MAPPING_FILE=data/processed/item_mapping.pkl


# Output configuration
MINING_OUTPUT_DIR=outputs/frequent_itemsets
SAVE_ITEMSETS=true
SAVE_RULES=true
SAVE_STATISTICS=true
